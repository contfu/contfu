FROM oven/bun:1.3.11-slim AS base
WORKDIR /app
RUN apt-get update && apt-get install -y ca-certificates wget && rm -rf /var/lib/apt/lists/*

FROM base AS build
COPY package.json bun.lock ./
COPY packages/ui/package.json packages/ui/
COPY packages/contfu/package.json packages/contfu/
COPY packages/media/bun-file-store/package.json packages/media/bun-file-store/
COPY packages/connect/package.json packages/connect/
COPY packages/media/media-optimizer/package.json packages/media/media-optimizer/
COPY packages/media/media-optimizer-remote/package.json packages/media/media-optimizer-remote/
COPY packages/core/package.json packages/core/
COPY packages/cli/package.json packages/cli/
COPY scripts/retry-timeout.sh scripts/
RUN --mount=type=cache,target=/root/.bun/install/cache ./scripts/retry-timeout.sh --timeout 60 --retries 3 -- bun install --ignore-scripts
COPY . .
RUN bun run -F '@contfu/ui' build

FROM base AS deps
WORKDIR /app
COPY packages/ui/package.json /app/package.json
COPY scripts/retry-timeout.sh scripts/
RUN --mount=type=cache,target=/root/.bun/install/cache \
  bun -p 'import {dependencies} from "./package.json"; JSON.stringify({dependencies})' > /tmp/pkg.json \
  && mv /tmp/pkg.json /app/package.json \
  && ./scripts/retry-timeout.sh --timeout 60 --retries 3 -- bun install --ignore-scripts --linker=hoisted

FROM base AS app
WORKDIR /app
ENV DATABASE_URL=/data/db
COPY --from=deps /app/node_modules/ /app/node_modules/
COPY --from=build /app/packages/ui/build/ /app/build/
COPY --from=build /app/packages/contfu/db/migrations/ /app/db/migrations/
COPY --from=build /app/packages/media/bun-file-store/src/ /app/node_modules/@contfu/bun-file-store/src/
COPY --from=build /app/packages/media/bun-file-store/package.json /app/node_modules/@contfu/bun-file-store/package.json
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD wget --spider -q http://localhost:3000/ || exit 1
CMD ["bun", "run", "./build/index.js"]
