{
  "name": "@contfu/svc-backend",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./domain/*": "./src/domain/*.ts",
    "./infra/*": "./src/infra/*.ts",
    "./features/*": "./src/features/*.ts",
    "./features/inflows": "./src/features/inflows/index.ts",
    "./features/schema-sync": "./src/features/schema-sync/index.ts",
    "./effect/*": "./src/effect/*.ts",
    "./push-worker/*": "./src/push-worker/*.ts"
  },
  "scripts": {
    "dev": "tsc -b --watch",
    "build": "[ -d dist ] || rm -f tsconfig.tsbuildinfo && tsc -b",
    "check": "tsc -p tsconfig.check.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "db:generate": "rm -rf db/migrations/*; drizzle-kit generate --name init",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@contfu/core": "workspace:*",
    "@contfu/svc-core": "workspace:*",
    "@contfu/svc-sources": "workspace:*",
    "@css-inline/css-inline": "^0.20.0",
    "@msgpack/msgpack": "^3.1.3",
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/kv": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1",
    "@polar-sh/better-auth": "^1.8.1",
    "@polar-sh/sdk": "^0.43.0",
    "better-auth": "^1.4.18",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "effect": "^4.0.0-beta.30",
    "msgpackr": "^1.11.8",
    "nodemailer": "^8.0.1",
    "sqids": "^0.3.0",
    "tiny-lru": "^11.4.7",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/nodemailer": "^7.0.9",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3"
  }
}
