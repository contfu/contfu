{
  "name": "@contfu/svc-backend",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./domain/*": "./dist/domain/*.js",
    "./infra/*": "./dist/infra/*.js",
    "./features/*": "./dist/features/*.js",
    "./features/influxes": "./dist/features/influxes/index.js"
  },
  "scripts": {
    "dev": "tsc -b --watch",
    "build": "[ -d dist ] || rm -f tsconfig.tsbuildinfo && tsc -b",
    "check": "tsc -p tsconfig-typecheck.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@contfu/core": "workspace:*",
    "@contfu/svc-core": "workspace:*",
    "@contfu/svc-sources": "workspace:*",
    "@css-inline/css-inline": "^0.20.0",
    "@msgpack/msgpack": "^3.1.3",
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/kv": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1",
    "@polar-sh/better-auth": "^1.8.1",
    "@polar-sh/sdk": "^0.43.0",
    "better-auth": "^1.4.18",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "msgpackr": "^1.11.8",
    "nodemailer": "^8.0.1",
    "sqids": "^0.3.0",
    "tiny-lru": "^11.4.7",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@types/nodemailer": "^7.0.9",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3"
  }
}
