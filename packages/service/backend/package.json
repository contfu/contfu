{
  "name": "@contfu/svc-backend",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./domain/*": "./dist/domain/*.js",
    "./infra/*": "./dist/infra/*.js",
    "./features/*": "./dist/features/*.js"
  },
  "scripts": {
    "dev": "tsc -b --watch",
    "build": "[ -d dist ] || rm -f tsconfig.tsbuildinfo && tsc -b",
    "check": "tsc -p tsconfig-typecheck.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "db:generate": "rm -rf db/migrations && drizzle-kit generate --name init",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@contfu/core": "workspace:*",
    "@css-inline/css-inline": "^0.19.1",
    "@notionhq/client": "^5.9.0",
    "@polar-sh/better-auth": "^1.6.4",
    "@polar-sh/sdk": "^0.42.2",
    "better-auth": "^1.4.15",
    "drizzle-orm": "^1.0.0-beta.12-a5629fb",
    "msgpackr": "^1.9.4",
    "nodemailer": "^7.0.12",
    "valibot": "latest"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.1",
    "drizzle-kit": "^1.0.0-beta.12-a5629fb",
    "typescript": "latest"
  }
}
