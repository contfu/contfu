{
  "name": "@contfu/svc-app",
  "version": "0.0.1",
  "private": true,
  "description": "Contfu cloud service application",
  "type": "module",
  "scripts": {
    "dev": "bun -b vite dev",
    "build": "SKIP_DB_INIT=true bun -b vite build",
    "preview": "bun -b vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "serve": "bun build/index.js",
    "clean": "rm -rf .svelte-kit build",
    "shadcn": "bunx shadcn-svelte",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@contfu/core": "workspace:*",
    "@contfu/svc-backend": "workspace:*",
    "@contfu/svc-sources": "workspace:*",
    "@tanstack/table-core": "^8.21.3",
    "bits-ui": "^2.15.5",
    "clsx": "^2.1.1",
    "msgpackr": "^1.11.8",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tiny-lru": "^11.4.7"
  },
  "devDependencies": {
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.58.2",
    "@polar-sh/better-auth": "^1.8.1",
    "@polar-sh/sdk": "^0.43.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.9",
    "autoprefixer": "^10.4.24",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^1.0.0-beta.12-a5629fb",
    "mode-watcher": "^1.1.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "remeda": "^2.33.6",
    "svelte": "^5.50.2",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.3.6",
    "svelte-sonner": "^1.0.7",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "valibot": "^1.2.0",
    "vite": "^7.3.1"
  },
  "link": "isolated",
  "trustedDependencies": [
    "sharp"
  ]
}
