{
  "name": "@contfu/svc-app",
  "version": "0.0.1",
  "private": true,
  "description": "Contfu cloud service application",
  "type": "module",
  "scripts": {
    "dev": "bun -b vite dev",
    "build": "bun -b vite build",
    "preview": "bun -b vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "serve": "bun build/index.js",
    "clean": "rm -rf .svelte-kit build",
    "shadcn": "bunx shadcn-svelte",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@contfu/core": "workspace:*",
    "@contfu/svc-backend": "workspace:*",
    "@tanstack/table-core": "^8.21.3",
    "bits-ui": "^2.15.4",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "valibot": "latest"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.57.0",
    "@sveltejs/kit": "latest",
    "@sveltejs/vite-plugin-svelte": "latest",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "latest",
    "autoprefixer": "latest",
    "mode-watcher": "^1.1.0",
    "playwright": "latest",
    "postcss": "latest",
    "svelte": "latest",
    "svelte-adapter-bun": "latest",
    "svelte-check": "latest",
    "tailwindcss": "latest",
    "tw-animate-css": "^1.4.0",
    "typescript": "latest",
    "vite": "latest"
  },
  "link": "isolated",
  "trustedDependencies": [
    "sharp"
  ]
}
