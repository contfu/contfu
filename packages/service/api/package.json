{
  "name": "@contfu/svc-api",
  "version": "0.0.7",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contfu/contfu.git"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pack": "bun ../../../scripts/pack-package.ts ."
  },
  "dependencies": {
    "@contfu/svc-core": "workspace:^"
  }
}
