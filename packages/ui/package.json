{
  "name": "@contfu/ui",
  "version": "0.0.8",
  "description": "Contfu client application with dashboard",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contfu/contfu.git"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun kill; bun -b vite dev",
    "build": "bun -b vite build",
    "pack": "bun pm pack",
    "preview": "bun kill; bun build/index.js",
    "kill": "lsof -ti :5173 | xargs kill -9",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "bun test src/",
    "serve": "bun build/index.js",
    "clean": "rm -rf dist build .svelte-kit",
    "shadcn": "bunx shadcn-svelte"
  },
  "dependencies": {},
  "devDependencies": {
    "@contfu/contfu": "workspace:*",
    "@contfu/core": "workspace:*",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.563.1",
    "@m4k/common": "^0.2.5",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/table-core": "^8.21.3",
    "@types/bun": "^1.3.12",
    "autoprefixer": "^10.4.27",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "drizzle-kit": "1.0.0-beta.19",
    "drizzle-orm": "1.0.0-beta.19",
    "mode-watcher": "^1.1.0",
    "postcss": "^8.5.9",
    "svelte": "^5.55.3",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "ts-essentials": "^10.1.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "valibot": "^1.3.1",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "typescript": "^5.6.3"
  },
  "optionalDependencies": {},
  "link": "isolated"
}
