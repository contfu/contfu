{
  "name": "@contfu/app",
  "version": "0.0.1",
  "private": true,
  "description": "Contfu client application with dashboard",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun -b vite dev",
    "build": "bun -b vite build",
    "preview": "bun -b vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "serve": "bun build/index.js",
    "test": "bun test",
    "clean": "rm -rf dist build .svelte-kit",
    "shadcn": "bunx shadcn-svelte"
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "@contfu/core": "workspace:*",
    "bits-ui": "^2.15.4",
    "clsx": "^2.1.1",
    "drizzle-orm": "^1.0.0-beta.12-a5629fb",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "contfu": "workspace:*",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/kit": "latest",
    "@sveltejs/vite-plugin-svelte": "latest",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "latest",
    "autoprefixer": "latest",
    "drizzle-kit": "^1.0.0-beta.12-a5629fb",
    "mode-watcher": "^1.1.0",
    "postcss": "latest",
    "svelte": "latest",
    "svelte-adapter-bun": "latest",
    "svelte-check": "latest",
    "tailwindcss": "latest",
    "ts-essentials": "^10.0.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "latest",
    "vite": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.6.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "link": "isolated"
}
