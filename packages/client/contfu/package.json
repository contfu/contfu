{
  "name": "contfu",
  "version": "0.0.1",
  "files": [
    "src",
    "dist",
    "db/migrations"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.bun.ts",
      "default": "./src/index.ts"
    },
    "./src/*": "./src/*"
  },
  "scripts": {
    "test": "bun test",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "db:generate": "rm -rf db/migrations && drizzle-kit generate --name init",
    "build:lib": "tsc -b",
    "build:db:node": "bun build ./src/infra/db/db-node.ts --target=node --outfile ./dist/db-node.js --external better-sqlite3 --external drizzle-orm/better-sqlite3 --external drizzle-orm/better-sqlite3/migrator",
    "build:db:bun": "bun build ./src/infra/db/db-bun.ts --target=bun --outfile ./dist/db-bun.js",
    "build": "bun run build:lib && bun run build:db:node && bun run build:db:bun"
  },
  "dependencies": {
    "@contfu/client": "workspace:*",
    "@contfu/core": "workspace:*",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "m4k": "^0.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "ts-essentials": "^10.1.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  }
}
