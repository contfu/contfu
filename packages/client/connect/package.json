{
  "name": "@contfu/connect",
  "version": "0.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contfu/contfu.git"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "pack": "bun pm pack",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contfu/core": "workspace:*",
    "msgpackr": "^1.11.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "ts-essentials": "^10.1.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "eventsource": "^4.1.0"
  }
}
