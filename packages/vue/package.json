{
  "name": "@contfu/vue",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contfu/contfu.git"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "test": "bun test src/",
    "build": "tsc -b",
    "pack": "bun ../../scripts/pack-package.ts .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contfu/core": "workspace:^"
  },
  "devDependencies": {
    "@vue/server-renderer": "^3",
    "typescript": "^5.9.3",
    "vue": "^3"
  },
  "peerDependencies": {
    "vue": ">=3"
  }
}
