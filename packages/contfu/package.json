{
  "name": "@contfu/contfu",
  "version": "0.0.10",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contfu/contfu.git"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.bun.ts",
      "default": "./src/index.ts"
    },
    "./src/*": "./src/*"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "bun": "./dist/index.bun.js",
        "default": "./dist/index.js"
      },
      "./dist/*": "./dist/*"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "test": "DATABASE_URL=:memory: bun test src/",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "db:generate": "rm -rf db/migrations && drizzle-kit generate --name init && bun run ./scripts/generate-js-migrations.ts",
    "build:lib": "tsc -b",
    "build:esm": "bun ../../scripts/rewrite-relative-esm-imports.ts ./dist",
    "pack": "bun ../../scripts/pack-package.ts .",
    "build": "bun run build:lib && bun run build:esm"
  },
  "dependencies": {
    "@contfu/connect": "workspace:^",
    "@contfu/core": "workspace:^",
    "drizzle-orm": "1.0.0-beta.19"
  },
  "devDependencies": {
    "@m4k/common": "^0.2.5",
    "@types/bun": "^1.3.12",
    "drizzle-kit": "1.0.0-beta.19",
    "ts-essentials": "^10.1.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@contfu/bun-file-store": "workspace:^",
    "@contfu/media-optimizer": "workspace:^",
    "@contfu/media-optimizer-remote": "workspace:^"
  }
}
