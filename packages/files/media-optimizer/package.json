{
  "name": "@contfu/media-optimizer",
  "version": "0.0.7",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contfu/contfu.git"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "test": "bun test src/",
    "build": "tsc -b",
    "pack": "bun ../../../scripts/pack-package.ts .",
    "clean": "rm -rf dist .tmp"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@m4k/common": "^0.2.6",
    "m4k": "^0.3.2",
    "sharp": "^0.34.5",
    "tasque": "^0.1.2"
  },
  "devDependencies": {
    "@contfu/bun-file-store": "workspace:*",
    "@contfu/contfu": "workspace:*",
    "@types/bun": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
