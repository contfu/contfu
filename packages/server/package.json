{
  "name": "@contfu/server",
  "version": "0.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contfu/contfu.git"
  },
  "bin": {
    "contfu-server": "./src/bin.ts"
  },
  "files": [
    "dist",
    "!dist/**/*.d.ts.map"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "bin": {
      "contfu-server": "./dist/bin.js"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "bun": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "bun run src/bin.ts",
    "pack": "bun ../../scripts/pack-package.ts .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contfu/connect": "workspace:*",
    "@contfu/contfu": "workspace:*",
    "@contfu/core": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
