@baseUrl = https://api.notion.com/v1
@authToken = {{$dotenv API_TOKEN}}

### Query Test 1
# @name test1
POST {{baseUrl}}/databases/{{$dotenv NOTION_DB_ID_1}}/query
Authorization: Bearer {{authToken}}
Notion-Version: 2022-06-28
Content-Type: application/json

{
}

### Get page
GET {{baseUrl}}/pages/{{test1.response.body.results[0].id}}
Authorization: Bearer {{authToken}}
Notion-Version: 2022-06-28

### Get content
GET {{baseUrl}}/blocks/{{test1.response.body.results[0].id}}/children
Authorization: Bearer {{authToken}}
Notion-Version: 2022-06-28

### Get content2
GET {{baseUrl}}/blocks/15e26736-4959-4e51-86fe-1f3bcafc6321/children
Authorization: Bearer {{authToken}}
Notion-Version: 2022-06-28
