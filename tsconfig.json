{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": false,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["@types/bun"]
  },
  "files": [],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/client/connect" },
    { "path": "./packages/client/client" },
    { "path": "./packages/client/bun-file-store" },
    { "path": "./packages/client/media-optimizer" },
    { "path": "./packages/service/core" },
  ]
}
