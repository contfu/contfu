#!/usr/bin/env bash
set -euo pipefail

# args: <oldsha> <newsha> <flag>
flag="${3:-0}"

# Only run on branch checkout / worktree creation
[ "$flag" = "1" ] || exit 0

pwt="$(git worktree list --porcelain | awk '$1=="worktree"{print $2; exit}')"
wt="$(git rev-parse --show-toplevel)"

# If the primary worktree is the same as the worktree, exit
[ "$pwt" = "$wt" ] && exit 0

bun install

while IFS= read -r -d '' file; do
  # Skip stale env files from the primary worktree if this checkout no longer has that package path.
  target_dir="$(dirname "$wt/$file")"
  [ -d "$target_dir" ] || continue

  ln -sf "$pwt/$file" "$wt/$file"
done < <(find "$pwt/packages" -name .env -print0)
