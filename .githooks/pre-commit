#!/usr/bin/env bash
set -euo pipefail

# Get staged files (excluding deleted files)
staged_files=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$staged_files" ]; then
  exit 0
fi

# Filter to formattable/lintable files
code_files=$(echo "$staged_files" | grep -E '\.(ts|tsx|js|jsx|svelte|json|css|html)$' || true)

if [ -n "$code_files" ]; then
  echo "→ Formatting staged files..."
  echo "$code_files" | xargs oxfmt --write
  echo "$code_files" | xargs git add

  echo "→ Linting staged files..."
  echo "$code_files" | xargs oxlint
fi

echo "→ Running unit tests..."
bun --filter '@contfu/*' test
