{
  "name": "contfu",
  "private": true,
  "workspaces": [
    "packages/client/*",
    "packages/service/*",
    "packages/cli",
    "packages/core",
    "packages/ui",
    "demos/*"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "test": "bun --filter '@contfu/*' test",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "E2E_FULL_FLOW=true bun run build && bun run --filter 'demo-consumer-app' build && playwright test -c tests/playwright.config.ts",
    "test:e2e:no-build": "E2E_FULL_FLOW=true playwright test -c tests/playwright.config.ts",
    "test:e2e:ui": "E2E_FULL_FLOW=true playwright test -c tests/playwright.config.ts --ui",
    "test:e2e:headed": "E2E_FULL_FLOW=true playwright test -c tests/playwright.config.ts --headed",
    "build": "bun --filter '@contfu/*' build",
    "clean": "bun --filter '@contfu/*' clean",
    "dev": "bun run --filter '@contfu/svc-backend' build && bun run --parallel -F '@contfu/svc-{backend,app}' -F '@contfu/app' dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:types": "oxlint --type-aware",
    "typecheck": "tsc -b tsconfig.check.json",
    "check": "bun run fmt && bun run build && bun run lint && bun run typecheck && bun run test",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "m4k": "^0.2.5",
    "svelte": "^5.50.2",
    "svelte-kit": "^1.2.0"
  },
  "devDependencies": {
    "@contfu/cli": "workspace:*",
    "@contfu/client": "workspace:*",
    "@contfu/core": "workspace:*",
    "@playwright/test": "1.58.2",
    "@types/bun": "^1.3.9",
    "@typescript/native-preview": "^7.0.0-dev.20260211.1",
    "contfu": "workspace:*",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.46.0",
    "oxlint-tsgolint": "^0.12.1",
    "playwright": "1.58.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "overrides": {
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "drizzle-orm": "1.0.0-beta.15-859cf75"
  }
}
