{
  "name": "contfu",
  "private": true,
  "workspaces": [
    "packages/client/*",
    "packages/service/*",
    "packages/core",
    "demos/*"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "test": "bun --filter '@contfu/*' test",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "bun setup:e2e && playwright test -c tests/playwright.config.ts",
    "test:e2e:ui": "bun setup:e2e && playwright test -c tests/playwright.config.ts --ui",
    "test:e2e:headed": "bun setup:e2e && playwright test -c tests/playwright.config.ts --headed",
    "setup:e2e": "bun tests/e2e/setup.ts",
    "build": "bun --filter '@contfu/*' build",
    "clean": "bun --filter '@contfu/*' clean",
    "dev": "bun run --filter '@contfu/svc-backend' build && bun run --filter '@contfu/svc-backend' dev & bun run --parallel --filter '@contfu/*app' dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:types": "oxlint --type-aware",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "svelte": "^5.50.2",
    "svelte-kit": "^1.2.0"
  },
  "devDependencies": {
    "@contfu/client": "workspace:*",
    "@contfu/core": "workspace:*",
    "@playwright/test": "1.58.2",
    "@types/bun": "^1.3.9",
    "@typescript/native-preview": "^7.0.0-dev.20260211.1",
    "oxfmt": "^0.31.0",
    "oxlint": "^1.46.0",
    "oxlint-tsgolint": "^0.12.1",
    "playwright": "1.58.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
