{
  "name": "contfu",
  "private": true,
  "workspaces": [
    "packages/client/*",
    "packages/service/*",
    "packages/core"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "test": "bun --filter '@contfu/*' test",
    "build": "bun --filter '@contfu/*' build",
    "dev": "bun --filter '@contfu/*' dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@typescript/native-preview": "^7.0.0-dev.20260119.1",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.39.0",
    "playwright": "^1.57.0"
  },
  "peerDependencies": {
    "typescript": "^5.6.3"
  }
}
