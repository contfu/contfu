{
  "name": "contfu",
  "private": true,
  "workspaces": [
    "packages/client/*",
    "packages/service/*",
    "packages/core",
    "demos/*"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "test": "bun --filter '@contfu/*' test",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "bun setup:e2e && npx playwright test -c tests/playwright.config.ts",
    "test:e2e:ui": "bun setup:e2e && npx playwright test -c tests/playwright.config.ts --ui",
    "test:e2e:headed": "bun setup:e2e && npx playwright test -c tests/playwright.config.ts --headed",
    "setup:e2e": "bun tests/e2e/setup.ts",
    "build": "bun --filter '@contfu/*' build",
    "clean": "bun --filter '@contfu/*' clean",
    "dev": "bun --filter '@contfu/*' dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "svelte": "^5.49.1",
    "svelte-kit": "^1.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bun": "^1.3.8",
    "@typescript/native-preview": "^7.0.0-dev.20260119.1",
    "oxfmt": "^0.24.0",
    "oxlint": "^1.39.0",
    "playwright": "^1.57.0"
  },
  "peerDependencies": {
    "typescript": "^5.6.3"
  }
}
