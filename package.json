{
  "name": "contfu",
  "private": true,
  "workspaces": [
    "packages/client/*",
    "packages/service/*",
    "packages/cli",
    "packages/core",
    "demos/*"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "test": "bun --filter '@contfu/*' test",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "E2E_FULL_FLOW=true NODE_ENV=test bun run build && bun run --filter 'demo-consumer-app' build && playwright test -c tests/playwright.config.ts",
    "test:e2e:no-build": "E2E_FULL_FLOW=true playwright test -c tests/playwright.config.ts",
    "test:e2e:ui": "E2E_FULL_FLOW=true playwright test -c tests/playwright.config.ts --ui",
    "test:e2e:headed": "E2E_FULL_FLOW=true playwright test -c tests/playwright.config.ts --headed",
    "test:svc-e2e": "bun run --cwd packages/service/app test:e2e",
    "test:svc-e2e:no-build": "bun run --cwd packages/service/app test:e2e:no-build",
    "test:svc-e2e:ui": "bun run --cwd packages/service/app test:e2e:ui",
    "test:e2e:local": "./scripts/e2e-local.sh",
    "build": "bun --filter '@contfu/*' build",
    "clean": "bun --filter '@contfu/*' clean",
    "dev": "bun run --parallel -F '@contfu/svc-app' -F '@contfu/app' dev",
    "dev:svc": "bun run --filter '@contfu/svc-app' dev",
    "dev:client": "bun run --filter '@contfu/client' build && bun run --parallel -F '@contfu/client' -F '@contfu/app' dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:types": "oxlint --type-aware",
    "typecheck": "tsc -b tsconfig.check.json",
    "check": "bun run fmt && bun run build && bun run lint && bun run typecheck && bun run test",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "contfu": "bun run --elide-lines=0 --filter '@contfu/cli' contfu",
    "events": "bun scripts/event-logger.ts"
  },
  "dependencies": {
    "m4k": "^0.2.5",
    "svelte": "^5.55.0",
    "svelte-kit": "^1.2.0"
  },
  "devDependencies": {
    "@contfu/cli": "workspace:*",
    "@contfu/client": "workspace:*",
    "@contfu/connect": "workspace:*",
    "@contfu/core": "workspace:*",
    "@playwright/test": "1.58.2",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260325.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.3",
    "playwright": "1.58.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "overrides": {
    "drizzle-kit": "1.0.0-beta.19",
    "drizzle-orm": "1.0.0-beta.19"
  }
}
